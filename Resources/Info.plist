<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>Echo</string>
    <key>CFBundleIdentifier</key>
    <string>dev.matheusmmjs.echo</string>
    <key>CFBundleName</key>
    <string>Echo</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <!-- LSUIElement: roda sem ícone no Dock (agente de menu bar) -->
    <key>LSUIElement</key>
    <true/>
    <!-- Chaves de uso obrigatórias: sem elas o macOS mata o processo ao
         tentar acessar microfone/reconhecimento de voz, sem nem mostrar
         o prompt de permissão. -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Echo usa o microfone para transcrever sua fala em texto enquanto você segura a tecla de ditado.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Echo usa o reconhecimento de fala nativo do macOS para transcrever sua voz localmente.</string>
</dict>
</plist>
